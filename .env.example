OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Optional: Use HuggingFace embeddings instead of OpenAI
# HUGGINGFACEHUB_API_TOKEN=your_hf_token_here

# ChromaDB settings
